<!-- ===================== PAGE TITLE ===================== -->
<div class="section" style="padding-bottom:0;">
  <div class="container-ati">
    <div class="section-divider"></div>
    <h2>About Us</h2>
    <p class="sub">Advanced Technological Institute &mdash; Badulla</p>
